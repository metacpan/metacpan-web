<span class="river-gauge-gauge" title="River stage [% $stage %]&#10;• [% $river.immediate %] direct [% pluralize('dependent', $river.immediate) %]&#10;• [% $river.total %] total [% pluralize('dependent', $river.total) %]">
%%          } else {
<span class="river-gauge-gauge" title="River stage [% $stage %]&#10;No dependents">
%%          }
%%      } else {
<span class="river-gauge-gauge" title="River data not yet available">
%%      }
  %% include "river/gauge.svg.tx" { river => $river }
</span>
%%  }
%%  else {
<object data="/dist/[% $distribution | uri %]/river.svg"
  type="image/svg+xml"
  width="24px"
  height="15px"
  alt="river gauge for [% $distribution %]"
  class="river-gauge-gauge"></object>
