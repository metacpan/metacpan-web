<!DOCTYPE html>
<html lang="en-US">
    <head>
        <title>[% $title || 'Search the CPAN' %] - metacpan.org</title>
        <link rel="preload" as="fetch" href="/account/login_status" crossorigin="anonymous" />
        %%  for $assets.grep(rx('\.css$')) -> $css {
        <link href="[% $css %]" rel="stylesheet" type="text/css">
        %%  }
        %%  for $assets.grep(rx('\.js$')) -> $js {
        <script src="[% $js %]" type="module"></script>
        %%  }
        %%  if $rss {
        <link rel="alternate" type="application/rss+xml" title="[% $rss_title || 'RSS' %]" href="[% $rss %]" />
        %%  }
        %%  if $canonical {
        <link rel="canonical" href="https://metacpan.org[% $canonical %]" />
        %%  }
        %%  if $meta_description {
        <meta name="description" content="[% $meta_description %]" />
        %%  }
        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5">
        <link rel="shortcut icon" href="/static/icons/favicon.ico">
        <link rel="apple-touch-icon" sizes="152x152" href="/static/icons/apple-touch-icon.png">
        <link rel="search" href="/static/opensearch.xml" type="application/opensearchdescription+xml" title="MetaCPAN">
        %%  block opengraph -> { }
    </head>
    <body>
        <nav class="navbar" aria-label="Main navigation">
            <div class="header-logo-large d-none d-sm-block">
              <a href="/" tabindex="0">
                <svg class="logo" role="img" aria-label="MetaCPAN">
                  <use class="logo" href="/static/images/metacpan-logo.svg#logo" />
                </svg>
              </a>
            </div>
            <div class="header-logo-icon d-block d-sm-none">
              <a href="/">
                <svg class="logo" role="img" aria-label="MetaCPAN">
                  <use class="logo" href="/static/images/metacpan-logo.svg#dots" />
                </svg>
              </a>
            </div>
            %%  block header_nav_menu -> {
            <ul class="nav navbar-nav menu-items d-none d-md-flex">
              <li><a href="/about">About</a></li>
              <li><a href="/about/sponsors">Sponsor</a></li>
              <li><a href="https://grep.metacpan.org/">grep::cpan</a></li>
              <li><a href="/recent">Recent</a></li>
              <li><a href="/about/faq">FAQ</a></li>
              <li><a href="/tools">Tools</a></li>
              <li><a href="https://api.metacpan.org/">API</a></li>
            </ul>
            %%  }
            <ul class="nav navbar-nav navbar-right ms-auto">
                <li class="d-block d-md-none">
                    <button type="button" class="searchbar-btn" aria-label="Search">
                        <i class="fa fa-search button-fa-icon" aria-hidden="true"></i>
                    </button>
                </li>
                %%  block search_bar -> {
                <li>
                <form action="/search" class="searchbar-form search-form">
                   <input type="hidden" name="size" id="metacpan_search-size" value="20">
                  <div>
                      <div class="search-group">
                        <i class="fa fa-search" aria-hidden="true"></i>
                        <input type="text" name="q" placeholder="Search the CPAN" size="41" autocorrect="off" autocapitalize="off" spellcheck="false" id="metacpan_search-input" class="form-control" value="[% $search_query %]">
                      </div>
                  </div>
                </form>
                </li>
                %%  }
                %%  block sidebar_toggle_button -> {
                    <li class="icon-slidepanel d-block d-md-none">
                      <button data-bs-toggle="slidepanel" data-bs-target=".slidepanel" aria-label="Open navigation menu" aria-expanded="false">
                        <span class="button-fa-icon">
                          <i class="fa fa-bars slidepanel-open" aria-hidden="true"></i>
                          <i class="fa fa-times slidepanel-close" aria-hidden="true"></i>
                        </span>
                      </button>
                    </li>
                %%  }
                <li class="dropdown login-dropdown show-logged-in">
                    <button type="button" class="dropdown-toggle" data-bs-toggle="dropdown" aria-label="Account" aria-expanded="false">
                      <i class="fa fa-user button-fa-icon logged-in-icon" aria-hidden="true"></i>
                      <i class="fas fa-chevron-down" aria-hidden="true"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/account/identities">Identities</a></li>
                        <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                        <li><a class="dropdown-item" href="/account/favorite/list">Favorites</a></li>
                        <li>
                            <button type="button" class="dropdown-item logout-button">
                              Logout
                            </button>
                        </li>
                    </ul>
                </li>
                <li class="dropdown login-dropdown show-logged-out">
                    <button type="button" class="dropdown-toggle" data-bs-toggle="dropdown" aria-label="Login" aria-expanded="false">
                      <i class="fa fa-user button-fa-icon avatar-placeholder" aria-hidden="true"></i>
                      <i class="fas fa-chevron-down" aria-hidden="true"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        %%  for ['GitHub', 'Google'] -> $identity {
                        <li>
                            <a class="dropdown-item" href="/login/[% $identity.lc() %]">
                                <i class="fab fa-[% $identity.lc() %] fa-fw" aria-hidden="true"></i>
                                [% $identity %]
                            </a>
                        </li>
                        %%  }
                    </ul>
                </li>
                <li class="dropdown login-dropdown hide-logged-in hide-logged-out">
                    <button aria-label="Account">
                      <i class="fa fa-user button-fa-icon" aria-hidden="true"></i>
                    </button>
                </li>
            </ul>
        </nav>
        <div class="page-content [% block page_content_class -> { } %]">
          <div id="perl-ad-target" class="top-notify-banner perl-ad-target">
          </div>
          <nav class="sidebar" aria-label="Section navigation">
            %%  block left_nav -> {
            <div class="slidepanel">
              <ul class="nav-list [% block left_nav_classes -> { } %]">
                  %% block left_nav_content -> {}
              </ul>
            </div>
            %%  }
          </nav>
          <div class="content-navigation">
            %%  block breadcrumbs -> { }
          </div>
          <main class="[% block content_classes -> { } %]">
            %%  block content -> { }
          </main>
          <div class="content-pagination">
            %%  block pagination -> { }
          </div>
        </div>
        <footer class="footer">
          <div class="footer-container">
            <div class="footer-social">
              <div class="footer-link footer-logo">
                <a href="/">
                  <img src="/static/images/metacpan-logo.svg" alt="MetaCPAN" />
                </a>
              </div>
              <a class="footer-social-link" href="https://github.com/metacpan" aria-label="MetaCPAN on GitHub">
                <i class="fab fa-github-square" aria-hidden="true"></i>
              </a>
              <a class="footer-social-link" href="https://fosstodon.org/@metacpan" aria-label="MetaCPAN on Mastodon">
                <i class="fab fa-mastodon" aria-hidden="true"></i>
              </a>
            </div>
            <div class="footer-links">
              <div class="footer-link">
                  <a href="/about">About</a>
              </div>
              <div class="footer-link">
                  <a href="/about/sponsors">Sponsor</a>
              </div>
              <div class="footer-link">
                  <a href="https://grep.metacpan.org">grep::cpan</a>
              </div>
              <div class="footer-link">
                  <a href="/recent">Recent</a>
              </div>
              <div class="footer-link">
                  <a href="/about/faq">FAQ</a>
              </div>
              <div class="footer-link">
                  <a href="/tools">Tools</a>
              </div>
              <div class="footer-link">
                  <a href="https://api.metacpan.org/">API</a>
              </div>
              <div class="footer-link">
                  <a href="https://www.perl.org/">Perl.org</a>
              </div>
            </div>
            <div class="footer-sponsors">
              <div class="footer-sponsor-row">
                <a class="footer-sponsor-link" target="_blank" href="https://www.bytemark.co.uk/" rel="noopener" title="Bytemark">
                  <img class="footer-sponsor-bytemark" src="/static/images/sponsors/bytemark_logo.svg" alt="Bytemark" loading="lazy">
                </a>
                <a class="footer-sponsor-link" target="_blank" href="https://www.datadoghq.com/" rel="noopener" title="Datadog">
                  <img class="footer-sponsor-datadog" src="/static/images/sponsors/datadog.svg" alt="Datadog" loading="lazy">
                </a>
                <a class="footer-sponsor-link" target="_blank" href="https://deriv.com/careers/" rel="noopener" title="Deriv">
                  <img class="footer-sponsor-deriv" src="/static/images/sponsors/deriv.svg" alt="Deriv" loading="lazy">
                </a>
                <a class="footer-sponsor-link" target="_blank" href="https://www.elastic.co/" rel="noopener" title="Elastic">
                  <img class="footer-sponsor-elastic" src="/static/images/sponsors/elastic.svg" alt="Elastic" loading="lazy">
                </a>
                <a class="footer-sponsor-link" target="_blank" href="https://www.fastly.com/" rel="noopener" title="Fastly">
                  <img class="footer-sponsor-fastly" src="/static/images/sponsors/fastly_logo.svg" alt="Fastly" loading="lazy">
                </a>
              </div>
              <div class="footer-sponsor-row">
                <a class="footer-sponsor-link" target="_blank" href="https://geocode.xyz" rel="noopener" title="Geolytica">
                  <img class="footer-sponsor-geocode" src="/static/images/sponsors/geocodelogo.svg" alt="Geolytica" loading="lazy">
                </a>
                <a class="footer-sponsor-link" target="_blank" href="https://www.iban.com/" rel="noopener" title="IBAN">
                  <img class="footer-sponsor-iban" src="/static/images/sponsors/iban-logo.png" alt="IBAN" loading="lazy">
                </a>
                <a class="footer-sponsor-link" target="_blank" href="https://www.liquidweb.com/" rel="noopener" title="Liquid Web">
                  <img class="footer-sponsor-liquidweb" src="/static/images/sponsors/liquidweb_logo.png" alt="Liquid Web" loading="lazy">
                </a>
                <a class="footer-sponsor-link" target="_blank" href="https://opencagedata.com" rel="noopener" title="OpenCage">
                  <img class="footer-sponsor-opencage" src="/static/images/sponsors/open-cage.svg" alt="OpenCage" loading="lazy">
                </a>
                <!-- Keep until at least March 1, 2027 -->
                <a class="footer-sponsor-link" target="_blank" href="https://www.perlfoundation.org/" rel="noopener" title="The Perl and Raku Foundation">
                  <img class="footer-sponsor-tprf" src="/static/images/sponsors/perl-onion.svg" alt="The Perl and Raku Foundation" loading="lazy">
                </a>
              </div>
            </div>
          </div>
        </footer>
        <div class="modal fade" tabindex="-1" id="metacpan_keyboard-shortcuts" aria-labelledby="keyboard-shortcuts-title">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h4 class="modal-title" id="keyboard-shortcuts-title">Keyboard Shortcuts</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body row">
                %% include inc::keyboard_shortcuts
              </div>

            </div>
          </div>
        </div>
    </body>
</html>
