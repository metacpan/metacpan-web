%%  cascade base
%%  override left_nav_classes -> { 'nav nav-pills flex-column' }
%%  override left_nav_content -> {
[%-
for [
  [ 'Tools',              '/tools' ],
  [ 'Pod Renderer',       '/pod2html' ],
  [ 'Lab: Dashboard',     '/lab/dashboard' ],
  [ 'Lab: Dependencies',  '/lab/dependencies' ],
] -> $l {
%]
<li>
    <a href="[% $l.1 %]" class="[% if $current[$l.1] { 'active' } %]"[% if $current[$l.1] { ' aria-current="page"' } %]>[% $l.0 %]</a>
</li>
%%  }
%%  }
